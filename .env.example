# 1) Copy this file to .env
# 2) Fill in the Kakao values from Kakao Developers.

# Required for Kakao "send message to me"
KAKAO_REST_API_KEY=
KAKAO_REDIRECT_URI=http://localhost:8765/callback

# Usually empty. Fill only if your Kakao app uses a client secret.
KAKAO_CLIENT_SECRET=

# Link shown inside Kakao message cards.
# Add this domain in Kakao Developers if Kakao asks for a registered web domain.
KAKAO_LINK_URL=https://finance.yahoo.com/markets

# Optional: comma-separated RSS feeds. Leave empty to use safe defaults.
NEWS_RSS_URLS=

# Optional: comma-separated symbols you own or watch.
# Example: WATCHLIST_SYMBOLS=AAPL,NVDA,TSLA
WATCHLIST_SYMBOLS=

# Optional: enables automatic economic release calendar from FRED.
FRED_API_KEY=

# Optional: enables earnings calendar for WATCHLIST_SYMBOLS.
ALPHA_VANTAGE_API_KEY=

# Optional: enables AI-based Korean news interpretation.
# If empty, the bot automatically uses the built-in rule-based analysis.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Optional but recommended for SEC EDGAR API requests.
SEC_USER_AGENT=market-briefing-bot contact@example.com

# Optional settings
REPORT_TIMEZONE=Asia/Seoul
MARKET_TIMEZONE=America/New_York
KAKAO_CHUNK_SIZE=180

# Recommended: send only a short Kakao message with the public report URL.
KAKAO_SEND_MODE=link
REPORT_PUBLIC_BASE_URL=https://magirl2.github.io/news-2/reports
